{
  "name": "socialdrop",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "account": "yarn hardhat:account",
    "account:generate": "yarn workspace @socialdrop/hardhat account:generate",
    "account:import": "yarn workspace @socialdrop/hardhat account:import",
    "account:reveal-pk": "yarn workspace @socialdrop/hardhat account:reveal-pk",
    "chain": "yarn hardhat:chain",
    "compile": "yarn hardhat:compile",
    "deploy": "yarn hardhat:deploy",
    "fork": "yarn hardhat:fork",
    "format": "yarn next:format && yarn hardhat:format",
    "generate": "yarn account:generate",
    "hardhat:account": "yarn workspace @socialdrop/hardhat account",
    "hardhat:chain": "yarn workspace @socialdrop/hardhat chain",
    "hardhat:check-types": "yarn workspace @socialdrop/hardhat check-types",
    "hardhat:clean": "yarn workspace @socialdrop/hardhat clean",
    "hardhat:compile": "yarn workspace @socialdrop/hardhat compile",
    "hardhat:deploy": "yarn workspace @socialdrop/hardhat deploy",
    "hardhat:flatten": "yarn workspace @socialdrop/hardhat flatten",
    "hardhat:fork": "yarn workspace @socialdrop/hardhat fork",
    "hardhat:format": "yarn workspace @socialdrop/hardhat format",
    "hardhat:generate": "yarn workspace @socialdrop/hardhat generate",
    "hardhat:hardhat-verify": "yarn workspace @socialdrop/hardhat hardhat-verify",
    "hardhat:lint": "yarn workspace @socialdrop/hardhat lint",
    "hardhat:lint-staged": "yarn workspace @socialdrop/hardhat lint-staged",
    "hardhat:test": "yarn workspace @socialdrop/hardhat test",
    "hardhat:verify": "yarn workspace @socialdrop/hardhat verify",
    "postinstall": "husky install",
    "ipfs": "yarn workspace @socialdrop/nextjs ipfs",
    "lint": "yarn next:lint && yarn hardhat:lint",
    "next:build": "yarn workspace @socialdrop/nextjs build",
    "next:check-types": "yarn workspace @socialdrop/nextjs check-types",
    "next:format": "yarn workspace @socialdrop/nextjs format",
    "next:lint": "yarn workspace @socialdrop/nextjs lint",
    "next:serve": "yarn workspace @socialdrop/nextjs serve",
    "precommit": "lint-staged",
    "start": "yarn workspace @socialdrop/nextjs dev",
    "test": "yarn hardhat:test",
    "vercel": "yarn workspace @socialdrop/nextjs vercel",
    "vercel:login": "yarn workspace @socialdrop/nextjs vercel:login",
    "vercel:yolo": "yarn workspace @socialdrop/nextjs vercel:yolo",
    "verify": "yarn hardhat:verify"
  },
  "resolutions": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "husky": "~9.1.6",
    "lint-staged": "~13.2.2"
  },
  "packageManager": "yarn@3.2.3",
  "engines": {
    "node": ">=20.18.3"
  },
  "dependencies": {
    "@coinbase/onchainkit": "0.38.19",
    "@neynar/nodejs-sdk": "^3.34.0",
    "@vercel/og": "^0.8.5"
  }
}
