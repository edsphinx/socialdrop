# Template for NextJS environment variables.

# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, you'll need to store the vars in Vercel/System config.

# If not set, sensible public defaults are used so developers can start prototyping out of the box,
# but we recommend getting your own API keys for production apps.

# To access the values stored in this env file you can use: process.env.VARIABLENAME
# You'll need to prefix the variables names with NEXT_PUBLIC_ if you want to access them on the client side.
# More info: https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables
NEXT_PUBLIC_ALCHEMY_API_KEY=
# Required for production: get your own at https://cloud.reown.com (WalletConnect)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
# Optional client-side RPC override for Base Sepolia (wagmi); falls back to https://sepolia.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# Neynar (Farcaster API)
NEYNAR_API_KEY_PERSONAL=
NEYNAR_SIGNER_UUID=
NEYNAR_WEBHOOK_SECRET=

# Blockchain
DEPLOYER_PRIVATE_KEY=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Database (Supabase/PostgreSQL)
DATABASE_URL=
DIRECT_URL=

# Demo mode: serves canned data with no DB/chain. Auto-on when DATABASE_URL is unset; set DEMO_MODE=true to force it, or false to require the real DB.
DEMO_MODE=

# Quick Auth domain (your deployed origin, e.g. socialdrop.live)
NEXT_PUBLIC_AUTH_DOMAIN=

# Rate limiting (Upstash Redis — optional in local dev; required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
