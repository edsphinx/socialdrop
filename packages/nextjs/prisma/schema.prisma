// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// CAMPAIGNS MODEL
// Stores the main information for each airdrop campaign.
model campaigns {
  id                Int      @id @default(autoincrement())
  name              String
  image_url         String?
  target_cast_hash  String   @unique // The hash of the cast users must "like"
  max_mints         Int      @default(100)
  created_at        DateTime @default(now())

  nft_image_url_level_1 String
  nft_image_url_level_2 String?
  nft_image_url_level_3 String?

  is_active         Boolean  @default(true)
  creator_fid       Int?

  // Relations: a campaign can have many minted NFTs and many game scores.
  nfts_minted       nfts_minted[]
  gamification_scores gamification_scores[]
}

// MINTED NFTS MODEL
// Records each NFT that has been delivered to prevent duplicates.
model nfts_minted {
  id                Int      @id @default(autoincrement())
  token_id          Int
  recipient_address String
  minted_at         DateTime @default(now())

  user_fid          Int?
  level             Int      @default(1) // Current NFT level

  // Relation: each mint record belongs to a campaign.
  campaign          campaigns @relation(fields: [campaign_id], references: [id])
  campaign_id       Int

  // Constraint: A user can only receive one NFT per campaign.
  @@unique([campaign_id, recipient_address])
}

// GAMIFICATION MODEL
// Stores participant scores in the "War of Influence".
model gamification_scores {
  id                  Int      @id @default(autoincrement())
  nft_holder_address  String   // The NFT owner's address
  score               Int      @default(0)
  tracked_cast_hash   String?  // The hash of the participant's cast being tracked

  nft_holder_fid      Int?

  // Relation: each score belongs to a campaign.
  campaign            campaigns @relation(fields: [campaign_id], references: [id])
  campaign_id         Int

  // Constraint: A user can only have one score per campaign.
  @@unique([campaign_id, nft_holder_address])
}
